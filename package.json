{
  "name": "orc",
  "version": "0.1.0",
  "description": "Multi-agent orchestrator swarm built on Pi SDK",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "orc": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "pkg": "npx @yao-pkg/pkg dist/index.js --target node18-linux-x64,node18-macos-x64,node18-win-x64 --output release/orc --no-bytecode --public",
    "release": "bash scripts/build-release.sh"
  },
  "keywords": ["agent", "orchestrator", "swarm", "pi", "coding"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@mariozechner/pi-ai": "latest",
    "@sinclair/typebox": "^0.34.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "yaml": "^2.4.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^6.0.0"
  }
}
